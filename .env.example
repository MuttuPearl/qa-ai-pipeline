# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Claude Model to use (optional, defaults to claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# Application Under Test
